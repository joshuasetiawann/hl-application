# ---- n8n stack configuration ----
# Copy this file to ".env" and fill in real values. NEVER commit the real ".env".
#   cp .env.example .env

# --- PostgreSQL (n8n stores workflows/executions here) ---
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=n8n

# --- n8n encryption key (encrypts saved credentials) ---
# MUST stay constant forever, or you lose access to all stored credentials.
# Generate one with:  openssl rand -hex 32
N8N_ENCRYPTION_KEY=change-me-run-openssl-rand-hex-32

# --- Public addressing ---
# Local dev: keep the defaults below.
# Production: set N8N_HOST to your domain, N8N_PROTOCOL=https,
#             WEBHOOK_URL=https://your-domain/, and N8N_SECURE_COOKIE=true.
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_PORT=5678
WEBHOOK_URL=http://localhost:5678/
N8N_SECURE_COOKIE=false

# --- Timezone for cron/schedule triggers ---
GENERIC_TIMEZONE=Asia/Jakarta
