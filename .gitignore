# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma / sqlite
/prisma/*.db
/prisma/*.db-journal
/prisma/dev.db*

# local verification artifacts (HTML DOM captures; not committed)
# — except the curated premium-UI showcase, which IS committed.
/screenshots/*
!/screenshots/premium-ui/

# ops runtime artifacts (logs + pid) — keep the folders, ignore their contents
/ops/logs/*
!/ops/logs/.gitkeep
/ops/runtime/*
!/ops/runtime/.gitkeep
