# =============================================================================
# Required environment variables. Copy to ".env" for local dev. On Vercel, set
# these in Project Settings -> Environment Variables (do NOT commit real values).
#
# Required on Vercel:  DATABASE_URL, AUTH_SECRET
# Optional (seed-only): ADMIN_USERNAME, ADMIN_PASSWORD
# =============================================================================

# ---- Database (PostgreSQL) ----
# The app uses PostgreSQL everywhere (local + Vercel). SQLite does NOT work on
# Vercel's read-only, ephemeral serverless filesystem.
# Get a free hosted Postgres from Vercel Postgres (Storage tab) or Neon/Supabase,
# then paste its connection string here (and into Vercel env vars):
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
# On Vercel Postgres you can skip DATABASE_URL — the app auto-detects the
# POSTGRES_PRISMA_URL / POSTGRES_URL vars that Vercel injects automatically.

# ---- Auth ----
# Long random string used to sign the session JWT (generate e.g. `openssl rand -hex 32`).
AUTH_SECRET="change-me-to-a-long-random-secret-string"

# ---- Single admin account (seeded by prisma/seed.ts) ----
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-strong-password"

# ---- Optional: include demo data (customers/products/bons) when seeding ----
# SEED_DEMO="true"
