# Database (SQLite by default; swap for a Postgres URL in production if desired)
DATABASE_URL="file:./dev.db"

# Auth: secret used to sign the session JWT (use a long random string in production)
AUTH_SECRET="change-me-to-a-long-random-secret-string"

# Single admin account (seeded by prisma/seed.ts)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"
