// PRODUCTION schema — PostgreSQL.
// Identical models to prisma/schema.prisma (which uses SQLite for local dev/tests).
// Use this for production deployments with a persistent Postgres database:
//   npx prisma generate --schema=prisma/schema.postgres.prisma
//   npx prisma db push  --schema=prisma/schema.postgres.prisma   (creates/updates schema)
// Money is stored as Float (double precision) but ALL money math is done with decimal.js
// in the application layer (src/lib/calc.ts) so there are no float money bugs.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Customer {
  id             String    @id @default(cuid())
  nama           String
  lmDiscounts    String    @default("[]") // JSON: number[]
  brDiscounts    String    @default("[]") // JSON: number[]
  bonusThreshold Float     @default(0)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  transactions   Transaction[]

  @@index([deletedAt])
  @@index([nama])
}

model Product {
  id         String    @id @default(cuid())
  nama       String
  hargaModal Float     @default(0)
  hargaBase  Float     @default(0)
  tipe       String // "LM" | "BR"
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  lines      TransactionLine[]

  @@index([deletedAt])
  @@index([tipe])
}

model Transaction {
  id                String    @id @default(cuid())
  tanggal           DateTime  @default(now())
  nomorBon          String    @unique
  customerId        String
  customer          Customer  @relation(fields: [customerId], references: [id])
  ongkir            Float     @default(0)
  deskripsi         String    @default("")
  isBonus           Boolean   @default(false)
  bonusUnitsGranted Int       @default(0)
  status            String    @default("PIUTANG") // "PIUTANG" | "LUNAS"
  paymentDate       DateTime?
  omzetTotal        Float     @default(0)
  profitTotal       Float     @default(0)
  amountOwed        Float     @default(0)
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  lines             TransactionLine[]

  @@index([customerId])
  @@index([tanggal])
  @@index([status])
  @@index([isBonus])
  @@index([deletedAt])
}

model TransactionLine {
  id                          String      @id @default(cuid())
  transactionId               String
  transaction                 Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productId                   String
  product                     Product     @relation(fields: [productId], references: [id])
  quantity                    Int
  productNameSnapshot         String
  productTypeSnapshot         String // "LM" | "BR"
  hargaBaseSnapshot           Float
  hargaModalSnapshot          Float
  discountStepsSnapshot       String // JSON: number[]
  discountedUnitPriceSnapshot Float
  lineOmzetSnapshot           Float
  lineProfitSnapshot          Float
  createdAt                   DateTime    @default(now())
  updatedAt                   DateTime    @updatedAt

  @@index([transactionId])
  @@index([productId])
}
